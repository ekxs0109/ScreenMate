{
  "name": "screenmate",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "e2e:prepare": "WXT_PUBLIC_SCREENMATE_API_BASE_URL=http://127.0.0.1:8787 WXT_PUBLIC_SCREENMATE_VIEWER_BASE_URL=http://127.0.0.1:4173 pnpm --filter @screenmate/extension build",
    "test:e2e": "pnpm e2e:prepare && playwright test",
    "test:e2e:ui": "pnpm e2e:prepare && playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jsdom": "^29.0.2",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
